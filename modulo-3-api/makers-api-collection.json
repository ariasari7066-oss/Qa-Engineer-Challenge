  "item": [
    {
      "name": "TC_API_01 - Crear usuario exitosamente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has ID\", function () {\r",
              "    pm.expect(json.id).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Name is correct\", function () {\r",
              "    pm.expect(json.name).to.eql(\"Test User\");\r",
              "});\r",
              "\r",
              "// Guardar variables para futuros endpoints\r",
              "pm.environment.set(\"userId\", json.id);\r",
              "pm.environment.set(\"userName\", json.name);\r",
              "pm.environment.set(\"userJob\", json.job);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Test User\",\r\n  \"job\": \"Automation Engineer\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{BaseURL}}/users",
          "host": [
            "{{BaseURL}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
