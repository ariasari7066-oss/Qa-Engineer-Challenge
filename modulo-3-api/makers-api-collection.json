    {
      "name": "TC_API_02 - Consultar usuario creado",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response has ID\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.id).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Name is correct\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.name).to.eql(\"Test User\");\r",
              "});\r",
              "\r",
              "// Guardar Id como variable para otros endpoints\r",
              "const json = pm.response.json();\r",
              "pm.environment.set(\"userId\", json.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Test User\",\r\n  \"job\": \"Automation Engineer\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users/:id",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
